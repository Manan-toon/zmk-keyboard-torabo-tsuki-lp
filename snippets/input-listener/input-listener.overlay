&pointing_listener {
    status = "okay";
    device = <&pointing_device>;

    // カーソル移動: XY反転（この基板の右ボール実装向け）→ 1.5倍速
    //   向きが片軸だけ逆なら (INPUT_TRANSFORM_X_INVERT) 等に、
    //   90度回転してるなら INPUT_TRANSFORM_XY_SWAP を追加
    input-processors =
        <&zip_xy_transform (INPUT_TRANSFORM_X_INVERT | INPUT_TRANSFORM_Y_INVERT)>,
        <&zip_xy_scaler 3 2>;

    // layer index 3,4（＝体感 layer 2,3）でスクロール
    //   zip_xy_to_scroll_mapper: 上下→縦、左右→横スクロール両対応
    //   zip_scroll_scaler 1 8: 縦横まとめて 1/8 に減速（数字を大きくするほど遅く）
    scroller {
        layers = <3 4>;
        input-processors =
            <&zip_xy_transform (INPUT_TRANSFORM_X_INVERT | INPUT_TRANSFORM_Y_INVERT)>,
            <&zip_xy_to_scroll_mapper>,
            <&zip_scroll_scaler 1 8>;
    };
};
